{
  "name": "claude-master-toolkit",
  "version": "0.1.12",
  "description": "Operation layer for Claude Code: local dashboard, cost telemetry, context-guardian hooks, persistent memory (Pandorica), model router, MCP server, and a tree-sitter symbol index — all offline.",
  "type": "module",
  "bin": {
    "ctk": "bin/ctk.js",
    "ctk-mcp": "bin/ctk-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "claude-dist/CLAUDE.md",
    "claude-dist/settings.patch.json",
    "claude-dist/agents",
    "claude-dist/hooks",
    "claude-dist/skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:cli": "tsx src/cli/index.ts",
    "build": "rm -rf dist && tsup --config tsup.config.ts && vite build",
    "build:cli": "tsup --config tsup.config.ts",
    "build:server": "tsup --config tsup.config.ts && vite build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "prepublishOnly": "npm run build",
    "reinstall": "./uninstall.sh && pnpm install && pnpm run db:migrate && pnpm run build && ./install.sh"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "dashboard",
    "cost",
    "tokens",
    "context-window",
    "mcp",
    "model-context-protocol",
    "pandorica",
    "memory",
    "model-router",
    "hooks",
    "agents",
    "sqlite",
    "tree-sitter",
    "ai",
    "llm",
    "metrics"
  ],
  "author": "Oliver Calderon <loviver@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loviver/claude-master-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/loviver/claude-master-toolkit/issues"
  },
  "homepage": "https://github.com/loviver/claude-master-toolkit#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-python",
      "tree-sitter-rust",
      "esbuild"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.9.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "lucide-react": "^1.8.0",
    "open": "^10.1.2",
    "ora": "^9.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "recharts": "^2.15.3",
    "tree-sitter": "^0.21.1",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-rust": "0.23.1",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.3"
  },
  "exports": {
    "./server": {
      "default": "./dist/server.js"
    }
  }
}
